# Directorio que contiene los CSV originales de DATATRAN (Latin-1, separador ;)
# Puede ser ruta absoluta o relativa al directorio desde donde se ejecuta el script.
# Los archivos convertidos se guardan automáticamente en <raíz del proyecto>/data/
CSV_SOURCE_DIR=/ruta/al/directorio/con/los/csvs/originales

# Token de acceso a MotherDuck (requerido por extract_openmeteo.py)
# Obtenerlo en: https://app.motherduck.com → Settings → Access tokens
MOTHERDUCK_TOKEN=tu_token_aqui
