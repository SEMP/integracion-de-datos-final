# MySQL (mismos valores que workspaces/containers/.env)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=airbyte
MYSQL_PASSWORD=tu_password
MYSQL_DATABASE=tf-datatran
MYSQL_CONTAINER=tf-mysql

# Airbyte
# AIRBYTE_URL es la URL de tu instancia de Airbyte
AIRBYTE_URL=http://localhost:8000
# AIRBYTE_CONNECTION_ID: obtenelo en Airbyte UI → Connections → <tu connection> → Settings → Connection ID
AIRBYTE_CONNECTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
